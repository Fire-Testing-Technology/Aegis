@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <div class="header-brand d-flex align-items-center gap-3">
                <FttLogo />
                <span class="header-title text-muted">License Management</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <ThemeToggle />
                <AuthorizeView>
                    <Authorized>
                        <span>@context.User.Identity?.Name</span>
                        <a class="btn btn-sm btn-outline-secondary" href="/logout">Sign out</a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
        <article class="content px-4 py-3">
            @Body
        </article>
    </main>
</div>
